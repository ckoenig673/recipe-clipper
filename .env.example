# Backend storage
RECIPES_DB_PATH=/app/data/recipes.db

# Published host ports
FRONTEND_PORT=8010
BACKEND_PORT=8015
OCR_WORKER_PORT=8787
# Legacy-compatible host port names retained for the social and whisper workers.
SOCIAL_DOWNLOADER_PORT=8790
WHISPER_PROCESSOR_PORT=8791

# Auth and browser session settings
AUTH_SESSION_TTL_HOURS=168
AUTH_COOKIE_NAME=recipe_clipper_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=
CORS_ALLOW_ORIGINS=http://localhost:8010,http://127.0.0.1:8010
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@example.local
AUTH_BOOTSTRAP_ADMIN_PASSWORD=change-me-now

# Optional Ollama integration for AI cleanup and review enhancement
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3:latest
OLLAMA_TIMEOUT_SECONDS=600

# Backend-to-worker URLs on the Docker Compose network.
# SOCIAL_DOWNLOADER_URL and WHISPER_PROCESSOR_URL are legacy-compatible names
# that still point to the current social-worker and whisper-worker services.
OCR_WORKER_URL=http://ocr:8787/ocr/image
OCR_WORKER_TIMEOUT_SECONDS=600
AI_REVIEW_ENABLED=true
AI_REVIEW_POLL_SECONDS=12
SOCIAL_DOWNLOADER_URL=http://social:8790/download/social-video

# Shared import artifact locations
SOCIAL_VIDEO_TMP_DIR=/app/data/social-downloads
WHISPER_PROCESSOR_URL=http://whisper:8791/transcribe
SOCIAL_DOWNLOADER_OUTPUT_DIR=/app/data/social-downloads

# Whisper worker defaults used when a request does not override them
WHISPER_MODEL=
WHISPER_DEVICE=
WHISPER_COMPUTE_TYPE=

# Backend-only fallback transcript pipeline settings.
# These are not used by the standard Docker Compose worker path, but they are real
# runtime settings for direct backend processing and are documented here so the
# configuration surface stays complete.
SOCIAL_VIDEO_FFMPEG_BIN=ffmpeg
SOCIAL_VIDEO_WHISPER_MODEL=small
SOCIAL_VIDEO_WHISPER_DEVICE=cpu
SOCIAL_VIDEO_WHISPER_COMPUTE_TYPE=int8
SOCIAL_VIDEO_MAX_TRANSCRIPT_CHARS=12000
SOCIAL_VIDEO_TRANSCRIPT_DEBUG_DIR=

# Frontend asset cache busting during image builds
CACHE_BUST_VERSION=20260511-1
