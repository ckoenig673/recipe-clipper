{
  "name": "Recipe Clipper",
  "short_name": "Recipe Clipper",
  "description": "Quickly save and organize recipes from links or text.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "theme_color": "#4caf50",
  "background_color": "#f3f4f6",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "/?share_target=1",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  }
}
